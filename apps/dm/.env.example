# Copy to .env.local and fill in real values. This file is safe to commit.

# MongoDB connection string. Use your own local or cloud URI.
# Local default (requires MongoDB running on localhost):
MONGODB_URI=mongodb://localhost:27017/dm

AUTH_SECRET=replace-with-a-long-random-secret-min-32-characters

PORT=3152
NEXT_PUBLIC_API_URL=http://localhost:3152

# ─── AI Content Generation ───────────────────────────────────────────────────
# Provide one of these to enable AI content generation.
# Anthropic is used first; OpenAI is the fallback.
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...

# ─── Email Sending ────────────────────────────────────────────────────────────
# Set EMAIL_PROVIDER to 'resend' or 'smtp'. Leave unset (or 'none') to log emails to console only.
# EMAIL_PROVIDER=resend
# RESEND_API_KEY=re_...
# EMAIL_FROM=noreply@yourdomain.com

# For SMTP (EMAIL_PROVIDER=smtp) — requires nodemailer to be installed:
# SMTP_HOST=smtp.yourprovider.com
# SMTP_PORT=587
# SMTP_USER=your@email.com
# SMTP_PASS=yourpassword

# ─── Google Reviews Import ────────────────────────────────────────────────────
# Required to import reviews from Google Places API.
# GOOGLE_PLACES_API_KEY=AIza...

# ─── Social Media Publishing ─────────────────────────────────────────────────
# Facebook / Instagram (uses Facebook Graph API)
# FACEBOOK_ACCESS_TOKEN=EAA...
# FACEBOOK_PAGE_ID=123456789

# LinkedIn
# LINKEDIN_ACCESS_TOKEN=AQV...

# Twitter / X (OAuth 1.0a signing not yet fully implemented)
# TWITTER_API_KEY=...
# TWITTER_API_SECRET=...
# TWITTER_ACCESS_TOKEN=...
# TWITTER_ACCESS_TOKEN_SECRET=...
